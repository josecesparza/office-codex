{
  "name": "@office-codex/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/app.ts --format esm --dts --clean",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@office-codex/assets": "workspace:*",
    "@office-codex/core": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "env-paths": "^3.0.0",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  }
}
