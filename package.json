{
  "name": "office-codex",
  "private": true,
  "version": "0.1.0",
  "description": "Pixel office dashboard for Codex sessions.",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @office-codex/daemon --filter @office-codex/web dev",
    "build": "pnpm -r build",
    "start": "node --import tsx apps/cli/src/index.ts dashboard",
    "office:dashboard": "node --import tsx apps/cli/src/index.ts dashboard",
    "office:doctor": "node --import tsx apps/cli/src/index.ts doctor",
    "test": "pnpm -r test",
    "test:smoke": "playwright test",
    "check": "pnpm -r check && biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@playwright/test": "^1.51.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
